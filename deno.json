{
  "tasks": {
    "check": "deno fmt --check && deno lint && deno check",
    "start": "deno run -A --watch=static/,routes/ dev.ts & deno task process:css",
    "build": "deno run -A dev.ts build",
    "preview": "deno serve -A _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update .",
    "process:drawings": "deno run -A process.svg.ts",
    "process:css": "deno run -A --watch=static/css/ process.css.ts"
  },
  "lint": { "rules": { "tags": ["fresh", "recommended"] } },
  "exclude": ["**/_fresh/*", "**/svgs.json", "**/static/*"],
  "imports": {
    "autoprefixer": "npm:autoprefixer@^10.4.23",
    "classnames": "npm:classnames@^2.5.1",
    "contentful": "https://esm.sh/contentful@9.3.5",
    "marked": "https://esm.sh/marked@4.3.0",
    "postcss": "npm:postcss@^8.5.6",
    "postcss-csso": "npm:postcss-csso@^6.0.1",
    "postcss-import": "npm:postcss-import@^16.1.1",
    "preact": "npm:preact@^10.27.2",
    "preact/hooks": "npm:preact@^10.27.2/hooks",
    "preact/jsx-runtime": "npm:preact@^10.27.2/jsx-runtime",
    "@preact/signals": "npm:@preact/signals@^2.5.0",
    "$std/": "https://deno.land/std@0.216.0/",
    "fresh": "jsr:@fresh/core@^2.2.0"
  },
  "compilerOptions": { "jsx": "react-jsx", "jsxImportSource": "preact" }
}
